FORM read_ekko_text_by_id USING    p_id   TYPE thead-tdid
                                    p_lang TYPE thead-tdspras
                                    p_name TYPE thead-tdname
                           CHANGING p_text TYPE znote2.
  DATA: lt_text TYPE TABLE OF tline,
        ls_text TYPE tdline.

  REFRESH lt_text.
  p_text = ''.

  CALL FUNCTION 'READ_TEXT'
    EXPORTING
      id                      = p_id
      language                = p_lang
      name                    = p_name
      object                  = 'EKKO'
    TABLES
      lines                   = lt_text
    EXCEPTIONS
      id                      = 1
      language                = 2
      name                    = 3
      not_found               = 4
      object                  = 5
      reference_check         = 6
      wrong_access_to_archive = 7
      OTHERS                  = 8.

  LOOP AT lt_text INTO ls_text.
    CONCATENATE p_text ls_text INTO p_text SEPARATED BY cl_abap_char_utilities=>newline.
  ENDLOOP.

  REPLACE ALL OCCURRENCES OF SUBSTRING '*' IN p_text WITH ''.
  REPLACE ALL OCCURRENCES OF SUBSTRING '<(>' IN p_text WITH ''.
  REPLACE ALL OCCURRENCES OF SUBSTRING '<)>' IN p_text WITH ''.
ENDFORM.

FORM fill_externalpo_section_nodes USING    p_lang TYPE thead-tdspras
                                            p_name TYPE thead-tdname
                                   CHANGING p_hd23 TYPE zmm_st_externalpo.
* Initialize/mapping from existing legacy fields
  CLEAR: p_hd23-special_terms,
         p_hd23-health_env_req,
         p_hd23-pre_shipment_advice,
         p_hd23-doc_required_clearance,
         p_hd23-shipment_advice,
         p_hd23-remarks,
         p_hd23-bank_details.

  p_hd23-special_terms          = p_hd23-po_hd_text.
  p_hd23-health_env_req         = p_hd23-delivery_method.
  p_hd23-pre_shipment_advice    = p_hd23-delivery_time.
  p_hd23-doc_required_clearance = p_hd23-doc_req.

* Dedicated Text IDs for additional sections
  PERFORM read_ekko_text_by_id USING 'F26' p_lang p_name CHANGING p_hd23-shipment_advice.
  PERFORM read_ekko_text_by_id USING 'F27' p_lang p_name CHANGING p_hd23-remarks.
  PERFORM read_ekko_text_by_id USING 'F28' p_lang p_name CHANGING p_hd23-bank_details.
ENDFORM.
