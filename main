*
*form entry_neu using ent_retco ent_screen.
*break ABAPCON01.
*  data: l_druvo like t166k-druvo,
*        l_nast  like nast,
*        l_from_memory,
*        l_doc   type meein_purchase_doc_print.
*
** ---------------------  here
* data : doc_no type ekko-EBELN,
*       doc_type TYPE ekko-bsart,
*       pur_grp type EKKO-EKGRP .
* doc_no = NAST-OBJKY.
* select single bsart EKGRP from ekko into (doc_type,pur_grp) where ebeln eq doc_no .
*
*
**  -------------------------------------------------------
**   F001
*IF Doc_type eq 'ZLPO'.
*
*TABLES : EKKO , EKPO , EKET , LFM1 .
*DATA : WA TYPE LINE OF  ZMM_TT_LOCALPO ,
*      IT TYPE  ZMM_TT_LOCALPO ,
*      HD TYPE ZMM_ST_LOCALPO ,
*      FT TYPE ZABAP_ST_FOOTER ,
*      H TYPE ZABAP_ST_HEADER ,
*      TOTAL TYPE NETWR ,
*      TOTAL_WORDS TYPE SPELL,
*      FRACTION TYPE NETWR,
*      DECIMAL TYPE NUM2,
*      TEXTT TYPE TABLE OF TLINE , TEXTS TYPE TDLINE ,TEXTF TYPE TDLINE,
*      NAME   TYPE THEAD-TDNAME,
*      LANG TYPE THEAD-TDSPRAS,
*       bland type adrc-REGION.
*TOTAL = 0 .
*HD-EBELN = doc_no.
*BREAK ABAPCON01 .
** GET HEADER DATA OF LOCAL PO FORM
*SELECT SINGLE BEDAT LIFNR BUKRS WAERS FROM EKKO INTO CORRESPONDING FIELDS OF HD
*  WHERE EBELN EQ HD-EBELN .
*
*SELECT SINGLE NAME1 NAME2 FROM LFA1 INTO ( HD-NAME1 , HD-NAME2 )
*  WHERE LIFNR EQ HD-LIFNR .
*
*SELECT SINGLE VERKF FROM LFM1 INTO HD-VERKF WHERE LIFNR EQ HD-LIFNR.
*
*CONCATENATE HD-NAME1 HD-NAME2 INTO HD-NAME1 SEPARATED BY ' ' .
**GET DELIVERY DATE
**SELECT SINGLE EINDT FROM EKET INTO HD-EINDT
**  WHERE EBELN EQ HD-EBELN .
*
*
**  GET TABLE DATA OF MATERIAL
*
*SELECT EBELP TXZ01 MATNR MEINS MENGE NETPR NETWR
*  FROM EKPO INTO CORRESPONDING FIELDS OF WA
*  WHERE EBELN EQ HD-EBELN.
*  TOTAL = TOTAL + WA-NETWR .
*
*
*  SELECT SINGLE EINDT
*  FROM  EKET INTO WA-EINDT
*  WHERE EBELN EQ HD-EBELN  AND EBELP EQ WA-EBELP .
*  SHIFT WA-EBELP LEFT DELETING LEADING '0'.
*  APPEND WA TO IT .
*  CLEAR WA .
*  ENDSELECT.
*
**SORT IT ASCENDING BY EBELP .
*
*
*  FRACTION = FRAC( TOTAL ).
*  HD-NETWR = TOTAL .
*  TOTAL = TOTAL - FRACTION .
*   FRACTION = FRACTION * 100 .
*
** SPELL_AMOUNT
*CALL FUNCTION 'ZSPELL_AMOUNT_AR'
* EXPORTING
*   AMOUNT         = TOTAL
*   CURRENCY       = HD-WAERS
**   FILTER         =
*   FRACTION       = FRACTION
* IMPORTING
*   IN_WORDS       = TOTAL_WORDS
*          .
*HD-WORDS = TOTAL_WORDS-WORD .
*
* BREAK ABAPCON01 .
*
*
**  Find Notes
*NAME = HD-EBELN .
*LANG = 'EN'.
*refresh textt.
*CALL FUNCTION 'READ_TEXT'
*  EXPORTING
**   CLIENT                        = SY-MANDT
*    ID                            = 'F02'
*    LANGUAGE                      = LANG
*    NAME                          = NAME
*    OBJECT                        = 'EKKO'
**   ARCHIVE_HANDLE                = 0
**   LOCAL_CAT                     = ' '
** IMPORTING
**   HEADER                        =
**   OLD_LINE_COUNTER              =
*  TABLES
*    LINES                         = TEXTT
* EXCEPTIONS
*   ID                            = 1
*   LANGUAGE                      = 2
*   NAME                          = 3
*   NOT_FOUND                     = 4
*   OBJECT                        = 5
*   REFERENCE_CHECK               = 6
*   WRONG_ACCESS_TO_ARCHIVE       = 7
*   OTHERS                        = 8
*          .
*IF SY-SUBRC <> 0.
** Implement suitable error handling here
*ENDIF.
*
*
** To find Text Note
*TextF = ''.
*LOOP AT TEXTT INTO TEXTS.
*  CONCATENATE TEXTF  TEXTS INTO TEXTF SEPARATED BY ' '.
*  ENDLOOP.
*  HD-NOTES = TEXTF .
*  REPLACE ALL OCCURRENCES OF SUBSTRING '*' IN HD-NOTES WITH ''.
*
*
*
**SELECT SINGLE COUNTRY REGION FROM ADRC INTO (FT-COUNTRY_EN , FT-REGION_EN)
**      WHERE ADDRNUMBER EQ FT-ADRNR  AND SPARS EQ 'EN' .
*
*
**  To find Footer
*SELECT SINGLE ADRNR FROM T001 INTO FT-ADRNR WHERE BUKRS EQ HD-BUKRS.
*
*SELECT SINGLE COUNTRY region FROM ADRC INTO (FT-COUNTRY,bland)
*      WHERE ADDRNUMBER EQ FT-ADRNR   .
**  SELECT SINGLE COUNTRY FROM ADRC INTO FT-COUNTRY_EN
**      WHERE ADDRNUMBER EQ FT-ADRNR   .
*SELECT SINGLE LANDX50 FROM T005T INTO FT-LANDX50_AR
*  WHERE LAND1 EQ FT-COUNTRY AND SPRAS EQ 'AR'.
*
*SELECT SINGLE LANDX50 FROM T005T INTO FT-LANDX50_EN
*  WHERE LAND1 EQ FT-COUNTRY AND SPRAS EQ 'EN'.
** ----------------------------
*
*SELECT SINGLE BEZEI FROM T005u INTO FT-REGION_AR
*  WHERE LAND1 EQ FT-COUNTRY AND SPRAS EQ 'AR' and bland eq bland.
*
*SELECT SINGLE BEZEI FROM T005u INTO FT-REGION_EN
*  WHERE LAND1 EQ FT-COUNTRY AND SPRAS EQ 'DE' and BLAND eq bland.
*
*
*
**   Find Header data
*H-ADDRNUMBER = FT-ADRNR.
*SELECT SINGLE NAME1 NAME2 SORT1 FROM ADRC INTO CORRESPONDING FIELDS OF H
*  WHERE ADDRNUMBER EQ H-ADDRNUMBER .
*
*
*CONCATENATE FT-LANDX50_EN ft-REGION_EN  into ft-landx50_en SEPARATED BY '-'.
*CONCATENATE FT-LANDX50_ar ft-REGION_ar  into ft-landx50_ar SEPARATED BY '-'.
**
**CONCATENATE H-name2 FT-REGION_AR INTO HD-TITLE_AR SEPARATED BY ' - '.
**CONCATENATE H-name1 FT-REGION_EN INTO HD-TITLE_EN SEPARATED BY ' - '.
*CONCATENATE 'بيانات' h-NAME2 INTO HD-title_AR SEPARATED BY ' '.
*
*
*
*
*SELECT SINGLE TEL_NUMBER FAX_NUMBER PO_BOX FROM ADRC INTO (FT-TEL_NUMBER , FT-FAX_NUMBER , FT-PO_BOX)
*  WHERE ADDRNUMBER EQ FT-ADRNR .
